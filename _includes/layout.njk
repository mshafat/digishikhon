<!DOCTYPE html>
<html lang="bn">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | My Blog</title>
    <style>
        :root { --bg: #ffffff; --text: #1a1a1a; --accent: #0070f3; }
        body { font-family: 'Inter', system-ui, sans-serif; line-height: 1.6; color: var(--text); background: var(--bg); max-width: 650px; margin: 40px auto; padding: 0 20px; }
        nav { display: flex; justify-content: space-between; margin-bottom: 60px; }
        a { color: inherit; text-decoration: none; transition: 0.2s; }
        a:hover { color: var(--accent); }
        h1 { font-weight: 800; letter-spacing: -1px; }
        .post-meta { font-size: 0.9rem; color: #666; }
        article img { max-width: 100%; border-radius: 8px; }
        footer { margin-top: 80px; border-top: 1px solid #eee; padding-top: 20px; font-size: 0.8rem; }
    </style>
</head>
<body>
    <nav>
        <a href="/"><strong>Minimalist.</strong></a>
        <div><a href="/admin">Admin</a></div>
    </nav>
    <main>
        {{ content | safe }}
    </main>
    <footer>© 2026 Personal Blog. Built with 11ty.</footer>
</body>
</html>